{
  "info": {
    "name": "MiniWallet API",
    "description": "API collection for the MiniWallet",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create User A",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/api/wallet/user",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "wallet",
            "user"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"NAJMI-001\",\n  \"name\": \"Muhammad Najmi Deraman\",\n  \"email\": \"najmideraman2000@example.com\"\n}"
        }
      }
    },
    {
